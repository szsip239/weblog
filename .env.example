# 微信公众号凭证
# 在 https://mp.weixin.qq.com → 开发 → 基本配置 中获取
WECHAT_APPID=your_appid_here
WECHAT_SECRET=your_secret_here

# 腾讯云 COS 图床
# 在 https://console.cloud.tencent.com/cos 中获取
COS_SECRET_ID=your_secret_id_here
COS_SECRET_KEY=your_secret_key_here
COS_BUCKET=your-bucket-name-1234567890
COS_REGION=ap-guangzhou
COS_PREFIX=article
